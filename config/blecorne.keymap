        // ====================================================
        // LAYER 8: BUTTONS
        // ====================================================
        BUT {
            display-name = "But";
            bindings = <LAYER_ADAPTER(
                &none,           &kp BTAB,        &kp MAC_FDPRV,   &kp MAC_FDNXT,   &kp TAB,         &kp MAC_LP,                              &kp MAC_LP,      &kp BTAB,        &kp MAC_FDPRV,   &kp MAC_FDNXT,   &kp TAB,         &none,
                &none,           &kp MAC_DKTP,    &kp MAC_WINP,    &kp MAC_WINN,    &kp MAC_DKTN,    &kp MAC_APPWIN,  &kp LHYP,    &kp RHYP,  &kp MAC_APPWIN,  &kp MAC_DKTP,    &kp MAC_WINP,    &kp MAC_WINN,    &kp MAC_DKTN,    &none,
                &none,           &kp LHRM4,        &kp LHRM3,       &kp LHRM2,       &kp LHRM1,       &kp MAC_MC,      &kp LMEH,    &kp RMEH,  &kp MAC_MC,      &kp RHRM1,       &kp RHRM2,       &kp RHRM3,       &kp RHRM4,       &none,
                &mt GLOBE MAC_REDO, &none,        &kp MAC_CUT,    &kp MAC_COPY,    &kp MAC_PASTE,   &kp MAC_SP,      &kp HOME,    &kp PG_UP, &kp MAC_SP,      &kp MAC_PASTE,   &kp MAC_COPY,    &kp MAC_CUT,     &none,           &mt GLOBE MAC_REDO,
