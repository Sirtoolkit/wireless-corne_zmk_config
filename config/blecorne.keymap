        };

        // ====================================================
        // LAYER 9: SYSTEM
        // ====================================================
        SYS {
            display-name = "Sys";
            bindings = <LAYER_ADAPTER(
                &none,           &none,           &none,           &none,           &none,           &none,                               &none,           &none,           &none,           &none,           &none,           &none,
                &none,           &none,           &none,           &none,           &none,           &none,           &kp LHYP,    &kp RHYP,  &none,           &none,           &none,           &none,           &none,           &none,
