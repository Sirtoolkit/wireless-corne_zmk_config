                &none,           &none,           &none,           &none,           &none,           &none,           &kp HOME,    &kp PG_UP, &none,           &none,           &none,           &none,           &none,           &none,
                                                 &to L_QWT,       &to L_CMK,       &none,            &none,           &kp END,     &kp PG_DN, &none,           &none,           &none,           &none
            )>;
